{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "ES2020",
        "allowJs": true,
        "noImplicitAny": true,
        "strict": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "lib": [
            "DOM",
            "ES2020"
        ],
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "outDir": "./dist"
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}